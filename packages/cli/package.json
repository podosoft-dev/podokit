{
  "name": "@podosoft/podokit",
  "version": "0.12.4",
  "description": "An opinionated but extensible starter toolkit and CLI for full-stack TypeScript apps with NestJS, SvelteKit, TailwindCSS, shadcn-svelte, Docker, and k3s.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/podosoft-dev/podokit.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "nestjs",
    "sveltekit",
    "starter",
    "cli",
    "scaffold",
    "tailwindcss",
    "shadcn"
  ],
  "bin": {
    "podo": "dist/index.js"
  },
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-templates.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@podosoft/podokit-template-engine": "^0.4.0"
  }
}
