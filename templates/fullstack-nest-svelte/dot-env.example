# Copy to .env and adjust. Never commit real secrets.

# ── Required (runtime) ───────────────────────────────────────────────
NODE_ENV=development
PORT=5002

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=podokit
POSTGRES_PASSWORD=podokit
POSTGRES_DB=podokit

# Web -> API boundary (server-side only; not exposed to the browser)
BACKEND_INTERNAL_URL=http://localhost:5002
CORS_ORIGIN=http://localhost:5001
# adapter-node request limit; leave room for a 2 MiB multipart upload
BODY_SIZE_LIMIT=3M

# ── Optional / development ───────────────────────────────────────────
# Redis — only needed by cache/queue modules (redis, bullmq, rate-limit,
# job-progress, sse). Start it with: docker compose --profile cache up
REDIS_HOST=localhost
REDIS_PORT=6379
